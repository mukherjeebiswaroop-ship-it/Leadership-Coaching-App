# ── WhatsApp Auto-Reply Agent Configuration ───────────────────────────────────

# The message sent automatically to every incoming WhatsApp message.
AUTO_REPLY_MESSAGE=Thank you for your message. Biswaroop will respond to you shortly.

# Set to "true" to also auto-reply inside group chats (default: false).
REPLY_TO_GROUPS=false

# Set to "false" to reply to EVERY message from a sender (not just the first).
# Default "true" means each sender gets at most one auto-reply per session.
REPLY_ONCE_PER_SENDER=true
